# Frontend environment — copy to .env.local (never commit the real file).
# Browser talks to the backend via its published host port (8100).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100/api/v1
NEXT_PUBLIC_PRODUCT_NAME=CoreOps

# Feature flags (default off). Attendance Corrections is deferred until
# biometric integration or automated attendance capture exists.
NEXT_PUBLIC_FEATURE_ATTENDANCE_CORRECTIONS=false
