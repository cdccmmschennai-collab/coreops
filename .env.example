# Docker Compose variables for the `wms` project.
# Copy to .env before running docker compose:  cp .env.example .env
# These are LOCAL defaults only — never commit a real .env.

# Postgres (container creds; host port 5433 maps to container 5432)
POSTGRES_USER=wms
POSTGRES_PASSWORD=wms
POSTGRES_DB=wms

# Host port bindings (must not collide with SPIR: 3000/8000/5432/6379)
FRONTEND_PORT=3100
BACKEND_PORT=8100
POSTGRES_PORT=5433
REDIS_PORT=6381
