# CoreOps backend environment — copy to .env, then edit.  NEVER commit the real .env.
#   cp backend/.env.example backend/.env
#
# This file is the single source of truth for configuration. app/core/config.py
# only holds local-dev fallback defaults; every value here overrides them with no
# source change. Precedence (highest first):
#   process env (systemd EnvironmentFile / docker-compose `environment:`)
#     > this .env file  >  the defaults baked into config.py
#
# The defaults below target a HOST-run backend (uvicorn on your machine) reaching
# the docker-published Postgres/Redis (host ports 5433 / 6381). Inside docker
# compose these are overridden to db:5432 / redis:6379. On the VPS, set the
# PRODUCTION values shown in the commented "# PROD:" lines.

# ---------------------------------------------------------------------------
# Runtime & security
# ---------------------------------------------------------------------------
# ENV: one of local | test | staging | production.
# The app FAILS TO START unless ENV is local/test OR SECRET_KEY is a strong,
# non-default value (>= 32 chars).
ENV=local
# PROD: ENV=production
SECRET_KEY=change-me-in-production
# PROD: SECRET_KEY=<64+ random chars, e.g. `openssl rand -base64 48`>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Datastores  (Postgres + Redis + Celery broker)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://wms:wms@localhost:5433/wms
# PROD: DATABASE_URL=postgresql+psycopg://<user>:<pass>@localhost:5432/<db>
#
# Redis: the cache/session store (…/0) and the Celery broker (…/1) are separate
# logical DBs on the same server. Local dev uses the docker-published port 6381;
# the VPS runs Redis natively on 6379 — set BOTH of these in the production .env.
REDIS_URL=redis://localhost:6381/0
CELERY_BROKER_URL=redis://localhost:6381/1
# PROD: REDIS_URL=redis://localhost:6379/0
# PROD: CELERY_BROKER_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
# Port uvicorn binds to (the coreops-api systemd unit reads this via ${BACKEND_PORT}).
BACKEND_PORT=8100
# API route prefix. Stable across environments - override only if you must.
# API_V1_PREFIX=/api/v1
# Comma-separated allowed browser origins.
CORS_ORIGINS=http://localhost:3100
# PROD: CORS_ORIGINS=https://coreops.cdccmms.com

PRODUCT_NAME=CoreOps

# First-admin bootstrap (used by `python -m scripts.seed_admin`; not auto-run in prod)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-strong

# ---------------------------------------------------------------------------
# Email / SMTP  (Daily Report Reminder notifications)
# EMAIL_ENABLED is a master switch — leave false until SMTP is verified; when
# false, sends are logged and skipped. Never commit real credentials.
# ---------------------------------------------------------------------------
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CoreOps
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=30
#
# PROD example (Brevo relay — put the real key ONLY in the server .env):
#   EMAIL_ENABLED=true
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USERNAME=<brevo-smtp-login>
#   SMTP_PASSWORD=<brevo-smtp-key>
#   SMTP_FROM=noreply@coreops.cdccmms.com
#   SMTP_FROM_NAME=CoreOps

# ---------------------------------------------------------------------------
# Daily Report Reminder schedule  (Celery beat; timezone is Asia/Kolkata)
# DEV: set REMINDER_EVERY_MINUTE=true to fire every minute while testing.
# PROD: keep it false so REMINDER_HOUR/REMINDER_MINUTE (09:30) take effect.
# REMINDER_SCHEDULE_ENABLED=false disables the schedule entirely (kill switch).
# ---------------------------------------------------------------------------
REMINDER_SCHEDULE_ENABLED=true
REMINDER_EVERY_MINUTE=false
REMINDER_HOUR=9
REMINDER_MINUTE=30

# Temporary debug endpoints (/debug/*). Enable only while verifying the pipeline;
# each route also requires the project_manager role. Keep false in production.
ENABLE_DEBUG_ENDPOINTS=false

# Split-day work reports (migration 0060). Periods are always maintained
# internally; this flag only gates whether report_mode='split_day' payloads are
# accepted. Keep in step with the frontend NEXT_PUBLIC_REPORT_DAY_PARTS_ENABLED.
REPORT_DAY_PARTS_ENABLED=true
