# Backend environment — copy to .env (never commit the real .env).
# These values target a HOST-run backend (uvicorn on your machine) reaching the
# Dockerized Postgres/Redis on their published host ports (5433 / 6381).
# When run INSIDE docker compose, these are overridden to db:5432 / redis:6379.

# ENV: one of local | test | staging | production.
# The app FAILS TO START unless ENV is local/test OR SECRET_KEY is a strong,
# non-default value (>= 32 chars). In production set ENV=production and a real
# secret, e.g.  SECRET_KEY=$(openssl rand -base64 48)
ENV=local
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg://wms:wms@localhost:5433/wms
REDIS_URL=redis://localhost:6381/0
CELERY_BROKER_URL=redis://localhost:6381/1

BACKEND_PORT=8100
CORS_ORIGINS=http://localhost:3100

PRODUCT_NAME=CoreOps

# First-admin bootstrap (used by `python -m scripts.seed_admin`; not auto-run in prod)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-strong

# ---------------------------------------------------------------------------
# Email / SMTP (Daily Report Reminder notifications)
# EMAIL_ENABLED is a master switch — leave false until SMTP is verified.
# Never commit real credentials.
# ---------------------------------------------------------------------------
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=CoreOps
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=30

# Gmail example (use a 16-char App Password, not your account password):
#   EMAIL_ENABLED=true
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=xxxxxxxxxxxxxxxx
#   SMTP_FROM=you@gmail.com

# ---------------------------------------------------------------------------
# Daily Report Reminder schedule (Celery beat, timezone Asia/Kolkata)
# For testing set REMINDER_EVERY_MINUTE=true; production uses HOUR/MINUTE (09:30).
# ---------------------------------------------------------------------------
REMINDER_SCHEDULE_ENABLED=true
REMINDER_EVERY_MINUTE=false
REMINDER_HOUR=9
REMINDER_MINUTE=30

# Temporary debug endpoints (/debug/*). Enable only while verifying the
# pipeline; each route also requires the project_manager role.
ENABLE_DEBUG_ENDPOINTS=false
